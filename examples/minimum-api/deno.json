{
  "lock": {
    "path": "./deno.lock",
    "frozen": true
  },
  "minimumDependencyAge": "P7D",
  "allowScripts": false,
  "tasks": {
    "swap": "dotenvx run -f .env.encrypted --strict -- deno run --allow-env --allow-net src/swap.ts",
    "lend": "dotenvx run -f .env.encrypted --strict -- deno run --allow-env --allow-net src/lend.ts",
    "dca": "dotenvx run -f .env.encrypted --strict -- deno run --allow-env --allow-net src/dca.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@t3-oss/env-core": "jsr:@t3-oss/env-core",
    "@solana/kit": "npm:@solana/kit@^6.8.0",
    "bs58": "npm:bs58@^6.0.0",
    "valibot": "npm:valibot@^1.3.1"
  }
}
